# Auth.js secret — generate with: openssl rand -base64 32
# Required for production and Docker Compose (copy this file to .env before `docker compose up`)
AUTH_SECRET=change-me-to-a-random-secret

# Public URL of the app (used for share links)
NEXTAUTH_URL=http://localhost:3000

# SQLite database path
DATABASE_URL=file:./data/app.db

# Audio upload directory
UPLOAD_DIR=./data/uploads

# Max upload size per clip in bytes (default 10MB)
MAX_UPLOAD_BYTES=10485760
